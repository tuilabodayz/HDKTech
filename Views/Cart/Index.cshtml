@model HDKTech.Models.Cart
@{
    ViewData["Title"] = "Giỏ Hàng - HDKTech";
}

<link rel="stylesheet" href="~/css/pages/cart.css" />

<div class="cart-container">
    <div class="container">
        <nav class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted">Trang chủ</a></li>
                <li class="breadcrumb-item active fw-bold text-danger">Giỏ hàng của bạn</li>
            </ol>
        </nav>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="cart-card">
                    <div class="cart-header">
                        <h4 class="fw-bold mb-0">Giỏ hàng <span class="badge bg-danger ms-2" id="cart-count">@Model.TotalItems</span></h4>
                        @if (!Model.IsEmpty) {
                            <form asp-action="Clear" method="post">
                                <button type="submit" class="btn btn-sm btn-link text-muted text-decoration-none" onclick="return confirm('Xoá toàn bộ giỏ hàng?')">
                                    <i class="bi bi-trash3 me-1"></i>Xoá tất cả
                                </button>
                            </form>
                        }
                    </div>

                    <div class="p-0">
                        @if (Model.IsEmpty) {
                            <div class="text-center py-5">
                                <i class="bi bi-cart-x display-1 text-light mb-3"></i>
                                <h5 class="text-muted">Giỏ hàng của bạn đang trống</h5>
                                <a asp-controller="Category" asp-action="Index" class="btn btn-outline-danger mt-3 rounded-pill px-4">Mua sắm ngay</a>
                            </div>
                        } else {
                            <div class="table-responsive">
                                <table class="table align-middle mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th class="ps-4 py-3 border-0">Sản phẩm</th>
                                            <th class="text-center py-3 border-0">Số lượng</th>
                                            <th class="text-end py-3 border-0">Thành tiền</th>
                                            <th class="pe-4 py-3 border-0"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.Items) {
                                            <tr id="row-@item.ProductId">
                                                <td class="ps-4 py-4">
                                                    <div class="d-flex align-items-center gap-3">
                                                        @* ImageUrl từ CartController đã là full path *@
                                                        <img src="@item.ImageUrl" 
                                                             class="product-img" 
                                                             data-category="@item.CategoryName"
                                                             onerror="handleCartImageError(this)"
                                                             data-product-id="@item.ProductId">
                                                        <div>
                                                            <h6 class="fw-bold mb-1">@item.ProductName</h6>
                                                            <span class="text-danger small fw-bold">@item.Price.ToString("#,##0")₫</span>
                                                            <br />
                                                            <small class="text-muted d-none">[DEBUG: Cat=@item.CategoryName | Img=@item.ImageUrl | ID=@item.ProductId]</small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="qty-group">
                                                        <button class="btn-qty" onclick="changeQty(@item.ProductId, -1)"><i class="bi bi-dash"></i></button>
                                                        <input type="number" id="qty-@item.ProductId" value="@item.Quantity" class="qty-input" readonly>
                                                        <button class="btn-qty" onclick="changeQty(@item.ProductId, 1)"><i class="bi bi-plus"></i></button>
                                                    </div>
                                                </td>
                                                <td class="text-end fw-bold text-dark">
                                                    <span id="total-@item.ProductId">@item.TotalPrice.ToString("#,##0")₫</span>
                                                </td>
                                                <td class="text-center pe-4">
                                                    <i class="bi bi-x-lg remove-btn" onclick="removeItem(@item.ProductId)"></i>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="summary-card card shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Chi tiết đơn hàng</h5>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Tạm tính</span>
                            <span class="fw-bold" id="summary-subtotal">@Model.TotalPrice.ToString("#,##0")₫</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Giao hàng</span>
                            <span class="text-success fw-bold">Miễn phí</span>
                        </div>
                        <hr>
                        <div class="mb-4">
                            <span class="text-muted d-block mb-1">Tổng cộng (Đã có VAT)</span>
                            <div class="summary-total-value" id="summary-total">@Model.TotalPrice.ToString("#,##0")₫</div>
                        </div>
                        
                        @if (!Model.IsEmpty) {
                            <a asp-controller="Checkout" asp-action="Index" class="btn-checkout text-white text-decoration-none">
                                <i class="bi bi-shield-check me-2"></i>TIẾN HÀNH ĐẶT HÀNG
                            </a>
                        } else {
                            <button class="btn btn-secondary w-100 py-3 disabled" disabled>GIỎ HÀNG TRỐNG</button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/cart-logic.js"></script>
}