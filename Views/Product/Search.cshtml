@model List<SanPham>

@{
    ViewData["Title"] = $"Kết quả tìm kiếm: {ViewBag.Keyword}";
    var currentSort = ViewBag.CurrentSort as string ?? "featured";
}

<link rel="stylesheet" href="~/css/pages/category.css" />

<div class="container-fluid my-4 px-lg-2">
    <!-- Filter Section -->
    <div class="filter-section bg-white p-3 rounded-3 shadow-sm mb-4 border-light">
        <form asp-action="Search" method="get" id="filterForm" class="w-100">
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted small"><i class="bi bi-house-fill me-1"></i>Trang chủ</a></li>
                    <li class="breadcrumb-item active small" aria-current="page">Kết quả tìm kiếm: <strong>@ViewBag.Keyword</strong></li>
                </ol>
            </nav>

            <input type="hidden" name="keyword" value="@ViewBag.Keyword" />

            <div class="d-flex flex-wrap gap-2 mb-3">
                <!-- Tình trạng -->
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-check-circle me-1"></i> Tình trạng
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&status=1&sortBy=@currentSort">Còn hàng</a></li>
                        <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&status=0&sortBy=@currentSort">Hết hàng</a></li>
                    </ul>
                </div>

                <!-- Giá -->
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-tag me-1"></i> Giá
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&minPrice=0&maxPrice=5000000&sortBy=@currentSort">Dưới 5 triệu</a></li>
                        <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&minPrice=5000000&maxPrice=10000000&sortBy=@currentSort">5 - 10 triệu</a></li>
                        <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&minPrice=10000000&maxPrice=20000000&sortBy=@currentSort">10 - 20 triệu</a></li>
                        <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&minPrice=20000000&maxPrice=999999999&sortBy=@currentSort">Trên 20 triệu</a></li>
                    </ul>
                </div>

                <!-- Hãng -->
                @if (ViewBag.Brands != null && ((List<string>)ViewBag.Brands).Any())
                {
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-building me-1"></i> Hãng
                        </button>
                        <ul class="dropdown-menu">
                            @foreach (var brand in ((List<string>)ViewBag.Brands).Take(10))
                            {
                                <li><a class="dropdown-item" href="?keyword=@ViewBag.Keyword&brandId=@brand.GetHashCode()&sortBy=@currentSort">@brand</a></li>
                            }
                        </ul>
                    </div>
                }
            </div>

            <!-- Sắp xếp -->
            <div class="d-flex justify-content-end border-top pt-3">
                <div class="sort-wrapper border rounded-2 px-3 py-1 bg-light">
                    <span class="small text-muted me-1">
                        <i class="bi bi-sort-down"></i> Xếp theo:
                    </span>
                    <select name="sortBy" class="border-0 bg-transparent fw-bold small sort-select shadow-none" style="cursor:pointer; outline:none;" onchange="document.getElementById('filterForm').submit();">
                        @if (currentSort == "featured")
                        {
                            <option value="featured" selected>Nổi bật</option>
                        }
                        else
                        {
                            <option value="featured">Nổi bật</option>
                        }
                        @if (currentSort == "name_asc")
                        {
                            <option value="name_asc" selected>Tên từ A-Z</option>
                        }
                        else
                        {
                            <option value="name_asc">Tên từ A-Z</option>
                        }
                        @if (currentSort == "name_desc")
                        {
                            <option value="name_desc" selected>Tên từ Z-A</option>
                        }
                        else
                        {
                            <option value="name_desc">Tên từ Z-A</option>
                        }
                        @if (currentSort == "price_asc")
                        {
                            <option value="price_asc" selected>Giá tăng dần</option>
                        }
                        else
                        {
                            <option value="price_asc">Giá tăng dần</option>
                        }
                        @if (currentSort == "price_desc")
                        {
                            <option value="price_desc" selected>Giá giảm dần</option>
                        }
                        else
                        {
                            <option value="price_desc">Giá giảm dần</option>
                        }
                        @if (currentSort == "new")
                        {
                            <option value="new" selected>Mới nhất</option>
                        }
                        else
                        {
                            <option value="new">Mới nhất</option>
                        }
                    </select>
                </div>
            </div>
        </form>
    </div>

    <!-- Products Grid -->
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
        @if (Model == null || Model.Count == 0)
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-5">
                    <i class="bi bi-search fs-1 d-block mb-3"></i>
                    <h5>Không tìm thấy sản phẩm</h5>
                    <p class="mb-0">Vui lòng thử từ khóa khác hoặc <a asp-controller="Home" asp-action="Index" class="fw-bold">quay lại trang chủ</a></p>
                </div>
            </div>
        }
        else
        {
            <div class="col-12 mb-3">
                <p class="text-muted mb-0">
                    Tìm kiếm cho: <strong class="text-dark">@ViewBag.Keyword</strong>
                    <span class="badge bg-secondary">@ViewBag.ResultCount kết quả</span>
                </p>
            </div>

            @foreach (var product in Model)
            {
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm product-card p-2">
                        <a asp-controller="Product" asp-action="Details" asp-route-id="@product.MaSanPham" class="text-decoration-none">
                            <div class="position-relative overflow-hidden rounded-3 text-center pt-3" style="height: 200px; background: #fff;">
                                @if (product.HinhAnhs != null && product.HinhAnhs.Any())
                                {
                                    var fileName = product.HinhAnhs?.FirstOrDefault(h => h.IsDefault)?.Url
                                                   ?? product.HinhAnhs?.FirstOrDefault()?.Url
                                                   ?? "no-image.png";
                                    var fullPath = "/images/products/" + fileName;

                                    <img src="@fullPath"
                                         class="card-img-top img-fluid product-img h-100"
                                         alt="@product.TenSanPham"
                                         style="object-fit: contain;"
                                         onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1588872657578-7efd1f1555ed?auto=format&fit=crop&w=500&q=60';">
                                }
                                else
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light">
                                        <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                                    </div>
                                }

                                @if (product.PhanTramGiamGia > 0)
                                {
                                    <span class="badge bg-danger position-absolute top-0 start-0 m-2 px-2 py-1 shadow-sm">
                                        -@product.PhanTramGiamGia%
                                    </span>
                                }
                            </div>
                        </a>

                        <div class="card-body d-flex flex-column px-2 pb-2">
                            <h6 class="card-title fw-bold text-dark text-truncate-2 mb-2">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@product.MaSanPham" class="text-decoration-none text-dark">
                                    @product.TenSanPham
                                </a>
                            </h6>

                            <p class="card-text small text-muted mb-2">
                                @if (product.HangSX != null)
                                {
                                    <span>@product.HangSX.TenHangSX</span>
                                }
                            </p>

                            <div class="mt-auto">
                                <div class="price-box mb-2">
                                    @if (product.GiaNiemYet.HasValue && product.GiaNiemYet > product.Gia && product.GiaNiemYet > 0)
                                    {
                                        <span class="text-decoration-line-through text-muted small me-1">
                                            @product.GiaNiemYet.Value.ToString("#,##0")₫
                                        </span>
                                    }

                                    <div class="d-flex align-items-center">
                                        <span class="fs-5 fw-bold text-danger me-2">@product.Gia.ToString("#,##0")₫</span>

                                        @if (product.PhanTramGiamGia > 0)
                                        {
                                            <span class="badge border border-danger text-danger bg-white p-1" style="font-size: 0.75rem;">
                                                -@product.PhanTramGiamGia%
                                            </span>
                                        }
                                    </div>
                                </div>

                                <div class="small mb-2">
                                    <span class="text-warning">4.9 <i class="bi bi-star-fill"></i></span>
                                    <span class="text-muted ms-1">(30 đánh giá)</span>
                                </div>

                                <button class="btn btn-outline-danger w-100 btn-sm fw-bold py-2 shadow-sm">
                                    <i class="bi bi-cart3 me-1"></i> THÊM GIỎ HÀNG
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
