@model HDKTech.Models.HomeIndexViewModel
@using HDKTech.Utils
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@{
    ViewData["Title"] = "Trang Chủ - HDKTech - Cửa Hàng Máy Tính Hàng Đầu";
}

<link rel="stylesheet" href="~/css/pages/home.css" />

<!-- ============================================
     1. CATEGORY-BASED HERO BANNER CAROUSEL
     ============================================ -->
<div id="categoryBannerCarousel" class="carousel slide carousel-fade banner-carousel" data-bs-ride="carousel" data-bs-interval="4000">
    <div class="carousel-indicators banner-indicators">
        @for (int i = 0; i < Model.Categories.Count; i++)
        {
            <button type="button"
                    data-bs-target="#categoryBannerCarousel"
                    data-bs-slide-to="@i"
                    class="@(i == 0 ? "active" : "")"
                    aria-current="@(i == 0 ? "true" : "false")"
                    aria-label="Slide @(i + 1)"></button>
        }
    </div>

    <div class="carousel-inner">
        @for (int i = 0; i < Model.Categories.Count; i++)
        {
            var category = Model.Categories[i];
            var colors = new[] { "#1e3c72", "#2a5298", "#0f3460", "#16213e", "#0b132b" };
            var bgColor = colors[i % colors.Length];
            
            var bannerFileName = "category-" + category.MaDanhMuc + ".jpg";
            var bannerPhysicalPath = System.IO.Path.Combine(Env.WebRootPath ?? "", "images", "banners", bannerFileName);
            var hasBanner = System.IO.File.Exists(bannerPhysicalPath);
            var bannerImg = hasBanner ? Url.Content("~/images/banners/" + bannerFileName) : null;
            
            var bgStyle = hasBanner
                ? $"background-image: linear-gradient(135deg, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.4) 100%), url('{bannerImg}');"
                : $"background-color: {bgColor}; background-image: linear-gradient(135deg, {bgColor} 0%, rgba(0,0,0,0.7) 100%);";

            <div class="carousel-item banner-item @(i == 0 ? "active" : "")">
                <div class="banner-background" style="@bgStyle background-size: cover; background-position: center;"></div>
                <div class="banner-overlay"></div>
                <div class="banner-content container">
                    <div class="banner-text d-flex flex-column align-items-center justify-content-center text-center w-100">
                        <h1 class="banner-title display-4 fw-bold text-white mb-3">@category.TenDanhMuc.ToUpper()</h1>
                        
                        <p class="banner-subtitle fs-5 mb-2 text-info uppercase shadow-sm">NÂNG TẦM TRẢI NGHIỆM SỐ</p>
                        
                        @if (!string.IsNullOrWhiteSpace(category.MoTaDanhMuc))
                        {
                            <p class="banner-description lead text-white-50 mb-4" style="max-width: 750px;">
                                @category.MoTaDanhMuc
                            </p>
                        }
                        
                        <a asp-controller="Category" asp-action="Index" asp-route-id="@category.MaDanhMuc" class="banner-btn btn btn-danger btn-lg rounded-pill px-5 shadow-lg">
                            <i class="bi bi-lightning-charge-fill me-2"></i> KHÁM PHÁ NGAY
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#categoryBannerCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#categoryBannerCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<!-- ============================================
     2. PROMO FEATURES (Backdrop Blur)
     ============================================ -->
<section class="service-highlights py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="service-item blurred">
                    <div class="service-icon gradient-center">
                        <i class="bi bi-truck"></i>
                    </div>
                    <h5 class="service-title">Giao Hàng Nhanh</h5>
                    <p class="service-desc">Giao trong 24-48h nội thành</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="service-item blurred">
                    <div class="service-icon gradient-center">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h5 class="service-title">Bảo Hành Chính Hãng</h5>
                    <p class="service-desc">24 tháng cho nhiều sản phẩm</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="service-item blurred">
                    <div class="service-icon gradient-center">
                        <i class="bi bi-credit-card"></i>
                    </div>
                    <h5 class="service-title">Trả Góp 0%</h5>
                    <p class="service-desc">Linh hoạt lên đến 12 tháng</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="service-item blurred">
                    <div class="service-icon gradient-center">
                        <i class="bi bi-headset"></i>
                    </div>
                    <h5 class="service-title">Hỗ Trợ 24/7</h5>
                    <p class="service-desc">Tư vấn mọi lúc</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================================
     3. FEATURED CATEGORIES (Grid Layout)
     ============================================ -->
<section class="featured-categories py-5">
    <div class="container">
        <div class="section-header">
            <div class="section-title"><i class="bi bi-grid-3x2"></i> DANH MỤC NỔI BẬT</div>
        </div>

        <div class="categories-grid">
            @if (Model.Categories.Any())
            {
                @foreach (var category in Model.Categories.Take(8))
                {
                    var catProduct = Model.AllProducts?.FirstOrDefault(p => p.MaDanhMuc == category.MaDanhMuc);
                    var catDefaultImage = catProduct?.HinhAnhs?.FirstOrDefault(h => h.IsDefault);
                    var catAnyImage = catProduct?.HinhAnhs?.FirstOrDefault();
                    var catImg = catDefaultImage?.Url ?? catAnyImage?.Url ?? "no-image.png";
                    var imgUrl = Url.Content("/images/products/" + catImg);

                    <a asp-controller="Category" asp-action="Index" asp-route-id="@category.MaDanhMuc" class="category-tile">
                        <div class="category-tile-image">
                            <img src="@imgUrl" alt="@category.TenDanhMuc" onerror="this.src='/images/products/no-image.png'" />
                            <div class="category-tile-overlay">
                                <h5 class="category-tile-name">@category.TenDanhMuc</h5>
                                <span class="category-tile-arrow"><i class="bi bi-arrow-right"></i></span>
                            </div>
                        </div>
                    </a>
                }
            }
        </div>
    </div>
</section>

<!-- ============================================
     4. FEATURED PRODUCTS & NEW ARRIVALS
     ============================================ -->
<section class="product-sections py-5">
    <div class="container">
        <!-- TOP SELLER PRODUCTS -->
        @if (Model.TopSellerProducts.Any())
        {
            <div class="product-section mb-5">
                <div class="section-header">
                    <div class="section-title"><i class="bi bi-lightning"></i> LAPTOP BÁN CHẠY</div>
                    <a asp-controller="Product" asp-action="Index" asp-route-sortOrder="popular" class="view-all-btn">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                <div class="products-grid">
                    @foreach (var product in Model.TopSellerProducts.Take(8))
                    {
                        <div class="product-card-wrapper">
                            <div class="product-card">
                                <div class="product-image-container">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@product.MaSanPham" class="product-image-link">
                                        @{
                                            var imgUrl = Url.Content("/images/products/" + (product.HinhAnhs?.FirstOrDefault(h => h.IsDefault)?.Url ?? product.HinhAnhs?.FirstOrDefault()?.Url ?? "no-image.png"));
                                        }
                                        <img src="@imgUrl" alt="@product.TenSanPham" class="product-image" onerror="this.src='/images/products/no-image.png'" />
                                    </a>

                                    @if (product.PhanTramGiamGia > 0)
                                    {
                                        <span class="product-badge-discount">-@product.PhanTramGiamGia%</span>
                                    }
                                    <span class="product-badge-new">MỚI</span>

                                    <button type="button" class="product-add-btn" onclick="addToCartAjax(@product.MaSanPham, '@product.TenSanPham')">
                                        <i class="bi bi-cart-plus"></i> Thêm Giỏ
                                    </button>
                                </div>

                                <div class="product-info">
                                    <h5 class="product-name">
                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@product.MaSanPham">
                                            @product.TenSanPham
                                        </a>
                                    </h5>

                                    <!-- Rating -->
                                    <div class="product-rating">
                                        <div class="rating-stars">
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                        </div>
                                        <span class="rating-count">Đã bán 234</span>
                                    </div>

                                    <div class="product-price-group">
                                        @if (product.GiaNiemYet.HasValue && product.GiaNiemYet > product.Gia)
                                        {
                                            <span class="product-price-old">@product.GiaNiemYet.Value.ToString("#,##0")₫</span>
                                        }
                                        <span class="product-price-current">@product.Gia.ToString("#,##0")₫</span>
                                    </div>

                                    <!-- Installment button -->
                                    <button type="button" class="btn-installment">
                                        <i class="bi bi-percent"></i> Trả góp 0%
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- NEW ARRIVALS -->
        @if (Model.NewProducts.Any())
        {
            <div class="product-section">
                <div class="section-header">
                    <div class="section-title"><i class="bi bi-star-fill"></i> LINH KIỆN MỚI VỀ</div>
                    <a asp-controller="Product" asp-action="Index" asp-route-sortOrder="newest" class="view-all-btn">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                <div class="products-grid">
                    @foreach (var product in Model.NewProducts.Take(8))
                    {
                        <div class="product-card-wrapper">
                            <div class="product-card">
                                <div class="product-image-container">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@product.MaSanPham" class="product-image-link">
                                        @{
                                            var imgUrl = Url.Content("/images/products/" + (product.HinhAnhs?.FirstOrDefault(h => h.IsDefault)?.Url ?? product.HinhAnhs?.FirstOrDefault()?.Url ?? "no-image.png"));
                                        }
                                        <img src="@imgUrl" alt="@product.TenSanPham" class="product-image" onerror="this.src='/images/products/no-image.png'" />
                                    </a>

                                    @if (product.PhanTramGiamGia > 0)
                                    {
                                        <span class="product-badge-discount">-@product.PhanTramGiamGia%</span>
                                    }
                                    <span class="product-badge-new">MỚI</span>

                                    <button type="button" class="product-add-btn" onclick="addToCartAjax(@product.MaSanPham, '@product.TenSanPham')">
                                        <i class="bi bi-cart-plus"></i> Thêm Giỏ
                                    </button>
                                </div>

                                <div class="product-info">
                                    <h5 class="product-name">
                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@product.MaSanPham">
                                            @product.TenSanPham
                                        </a>
                                    </h5>

                                    <!-- Rating -->
                                    <div class="product-rating">
                                        <div class="rating-stars">
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                        </div>
                                        <span class="rating-count">Đã bán 234</span>
                                    </div>

                                    <div class="product-price-group">
                                        @if (product.GiaNiemYet.HasValue && product.GiaNiemYet > product.Gia)
                                        {
                                            <span class="product-price-old">@product.GiaNiemYet.Value.ToString("#,##0")₫</span>
                                        }
                                        <span class="product-price-current">@product.Gia.ToString("#,##0")₫</span>
                                    </div>

                                    <!-- Installment button -->
                                    <button type="button" class="btn-installment">
                                        <i class="bi bi-percent"></i> Trả góp 0%
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>
@section Scripts {
    <script src="~/js/pages/home.js"></script>
}

@* Cart functionality is now in global wwwroot/js/cart.js *@
