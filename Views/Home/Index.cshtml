@model HDKTech.Models.HomeIndexViewModel
@using HDKTech.Utils
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@{
    ViewData["Title"] = "Trang Chủ - HDKTech - Cửa Hàng Máy Tính Hàng Đầu";
}

<link rel="stylesheet" href="~/css/pages/home.css" />

<!-- ============================================
     1. HERO BANNER CAROUSEL (Admin-Managed)
     ============================================ -->
@if (Model.MainBanners.Any())
{
    @* Dùng container-fluid p-0 để banner tràn sát mép trái phải *@
    <div class="container-fluid p-0 mb-0">
        <div id="mainBannerCarousel" class="carousel slide carousel-fade main-banner-carousel" data-bs-ride="carousel" data-bs-interval="5000">
            <div class="carousel-inner">
                @foreach (var banner in Model.MainBanners)
                {
                    <div class="carousel-item @(Model.MainBanners.IndexOf(banner) == 0 ? "active" : "")">
                        <a href="@banner.LinkBanner" class="banner-link" target="@(banner.LinkBanner?.StartsWith("http") == true ? "_blank" : "_self")" onclick="trackBannerClick(@banner.MaBanner)">
                            @* CHỈNH SỬA TẠI ĐÂY: 
                                - Đổi height: 400px thành 75vh (chiếm 75% chiều cao màn hình) hoặc 600px
                                - Thêm d-block w-100 để đảm bảo ảnh phủ kín ngang
                            *@
                            <img src="@banner.ImageUrl" alt="@banner.TenBanner" class="d-block w-100" 
                                 style="height: 75vh; min-height: 500px; object-fit: cover;">
                            
                            <div class="carousel-caption d-md-block" style="bottom: 20%; background: rgba(0,0,0,0.2); backdrop-filter: blur(5px); border-radius: 15px; padding: 20px;">
                                <h2 class="fw-bold display-4" style="text-shadow: 2px 2px 10px rgba(0,0,0,0.8);">@banner.TenBanner</h2>
                                <p class="lead fs-4" style="text-shadow: 1px 1px 5px rgba(0,0,0,0.6);">@banner.MoTa</p>
                            </div>
                        </a>
                    </div>
                }
            </div>

            @if (Model.MainBanners.Count > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#mainBannerCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#mainBannerCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>

                <div class="carousel-indicators">
                    @foreach (var banner in Model.MainBanners)
                    {
                        <button type="button" data-bs-target="#mainBannerCarousel" data-bs-slide-to="@Model.MainBanners.IndexOf(banner)" 
                                class="@(Model.MainBanners.IndexOf(banner) == 0 ? "active" : "")" aria-current="@(Model.MainBanners.IndexOf(banner) == 0 ? "true" : "false")"></button>
                    }
                </div>
            }
        </div>
    </div>
}
else
{
    <div class="alert alert-info text-center py-5 m-0">
        <p class="mb-0">Chưa có banner nào. <a href="/Admin/Banner">Tạo banner ngay</a></p>
    </div>
}

<!-- ============================================
     2. PROMO FEATURES (Backdrop Blur)
     ============================================ -->
<section class="service-highlights py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-6 col-md-3">
                <div class="service-item blurred">
                    <div class="service-icon gradient-center">
                        <i class="bi bi-truck"></i>
                    </div>
                    <h5 class="service-title">Giao Hàng Nhanh</h5>
                    <p class="service-desc">Giao trong 24-48h nội thành</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="service-item blurred">
                    <div class="service-icon gradient-center">
                        <i class="bi bi-shield-check"></i>
                    </div>
                    <h5 class="service-title">Bảo Hành Chính Hãng</h5>
                    <p class="service-desc">24 tháng cho nhiều sản phẩm</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="service-item blurred">
                    <div class="service-icon gradient-center">
                        <i class="bi bi-credit-card"></i>
                    </div>
                    <h5 class="service-title">Trả Góp 0%</h5>
                    <p class="service-desc">Linh hoạt lên đến 12 tháng</p>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="service-item blurred">
                    <div class="service-icon gradient-center">
                        <i class="bi bi-headset"></i>
                    </div>
                    <h5 class="service-title">Hỗ Trợ 24/7</h5>
                    <p class="service-desc">Tư vấn mọi lúc</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================================
     3. FEATURED CATEGORIES
     ============================================ -->
<section class="featured-categories py-5 bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold section-title-main">Danh Mục</h2>
            <div class="title-underline mx-auto"></div>
        </div>

        @if (Model.Categories.Any())
        {
            <div class="row g-4 justify-content-center">
                @* Lấy các danh mục chính (Tầng 1 - Parent) để hiển thị ra icon tròn.
                   Nếu bạn muốn hiện cả các nhóm con, chỉ cần bỏ điều kiện .Where đi.
                *@
                @foreach (var category in Model.Categories.Where(m => m.MaDanhMucCha == null).Take(14))
                {
                    // Link lấy tương tự sidebar: Controller="Category", Action="Index", Route-id="MaDanhMuc"
                    <div class="col-4 col-md-3 col-lg-2">
                        <a asp-controller="Category" asp-action="Index" asp-route-id="@category.MaDanhMuc"
                               class="text-decoration-none category-item-modern">
            
                            <div class="category-icon-wrapper shadow-sm mb-3">
                                @* Đường dẫn ảnh: /images/banners/category-{MaDanhMuc}.jpg *@
                                <img src="/images/banners/category-@(category.MaDanhMuc).jpg"
                                     alt="@category.TenDanhMuc"
                                     onerror="this.src='/images/banners/category-1.jpg'"
                                     class="img-fluid p-3 category-img-render">
                            </div>
            
                            <h6 class="category-name-modern text-center">@category.TenDanhMuc</h6>
                        </a>
                    </div>
                }
            </div>
        }
    </div>
</section>

<!-- ============================================
     4. FEATURED PRODUCTS & NEW ARRIVALS
     ============================================ -->
<section class="product-sections py-5">
    <div class="container">
        <!-- TOP SELLER PRODUCTS -->
        @if (Model.TopSellerProducts.Any())
        {
            <div class="product-section mb-5">
                <div class="section-header">
                    <div class="section-title"><i class="bi bi-lightning"></i> LAPTOP BÁN CHẠY</div>
                    <a asp-controller="Product" asp-action="Index" asp-route-sortOrder="popular" class="view-all-btn">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                <div class="products-grid">
                    @foreach (var product in Model.TopSellerProducts.Take(8))
                    {
                        <div class="product-card-wrapper">
                            <div class="product-card">
                                <div class="product-image-container">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@product.MaSanPham" class="product-image-link">
                                        @{
                                            var imgUrl = Url.Content("/images/products/" + (product.HinhAnhs?.FirstOrDefault(h => h.IsDefault)?.Url ?? product.HinhAnhs?.FirstOrDefault()?.Url ?? "no-image.png"));
                                        }
                                        <img src="@imgUrl" alt="@product.TenSanPham" class="product-image" onerror="this.src='/images/products/no-image.png'" />
                                    </a>

                                    @if (product.PhanTramGiamGia > 0)
                                    {
                                        <span class="product-badge-discount">-@product.PhanTramGiamGia%</span>
                                    }
                                    <span class="product-badge-new">MỚI</span>

                                    <button type="button" class="product-add-btn" onclick="addToCartAjax(@product.MaSanPham, '@product.TenSanPham')">
                                        <i class="bi bi-cart-plus"></i> Thêm Giỏ
                                    </button>
                                </div>

                                <div class="product-info">
                                    <h5 class="product-name">
                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@product.MaSanPham">
                                            @product.TenSanPham
                                        </a>
                                    </h5>

                                    <!-- Rating -->
                                    <div class="product-rating">
                                        <div class="rating-stars">
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                        </div>
                                        <span class="rating-count">Đã bán 234</span>
                                    </div>

                                    <div class="product-price-group">
                                        @if (product.GiaNiemYet.HasValue && product.GiaNiemYet > product.Gia)
                                        {
                                            <span class="product-price-old">@product.GiaNiemYet.Value.ToString("#,##0")₫</span>
                                        }
                                        <span class="product-price-current">@product.Gia.ToString("#,##0")₫</span>
                                    </div>

                                    <!-- Installment button -->
                                    <button type="button" class="btn-installment">
                                        <i class="bi bi-percent"></i> Trả góp 0%
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- NEW ARRIVALS -->
        @if (Model.NewProducts.Any())
        {
            <div class="product-section">
                <div class="section-header">
                    <div class="section-title"><i class="bi bi-star-fill"></i> LINH KIỆN MỚI VỀ</div>
                    <a asp-controller="Product" asp-action="Index" asp-route-sortOrder="newest" class="view-all-btn">
                        Xem tất cả <i class="bi bi-arrow-right"></i>
                    </a>
                </div>

                <div class="products-grid">
                    @foreach (var product in Model.NewProducts.Take(8))
                    {
                        <div class="product-card-wrapper">
                            <div class="product-card">
                                <div class="product-image-container">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@product.MaSanPham" class="product-image-link">
                                        @{
                                            var imgUrl = Url.Content("/images/products/" + (product.HinhAnhs?.FirstOrDefault(h => h.IsDefault)?.Url ?? product.HinhAnhs?.FirstOrDefault()?.Url ?? "no-image.png"));
                                        }
                                        <img src="@imgUrl" alt="@product.TenSanPham" class="product-image" onerror="this.src='/images/products/no-image.png'" />
                                    </a>

                                    @if (product.PhanTramGiamGia > 0)
                                    {
                                        <span class="product-badge-discount">-@product.PhanTramGiamGia%</span>
                                    }
                                    <span class="product-badge-new">MỚI</span>

                                    <button type="button" class="product-add-btn" onclick="addToCartAjax(@product.MaSanPham, '@product.TenSanPham')">
                                        <i class="bi bi-cart-plus"></i> Thêm Giỏ
                                    </button>
                                </div>

                                <div class="product-info">
                                    <h5 class="product-name">
                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@product.MaSanPham">
                                            @product.TenSanPham
                                        </a>
                                    </h5>

                                    <!-- Rating -->
                                    <div class="product-rating">
                                        <div class="rating-stars">
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                            <i class="bi bi-star-fill"></i>
                                        </div>
                                        <span class="rating-count">Đã bán 234</span>
                                    </div>

                                    <div class="product-price-group">
                                        @if (product.GiaNiemYet.HasValue && product.GiaNiemYet > product.Gia)
                                        {
                                            <span class="product-price-old">@product.GiaNiemYet.Value.ToString("#,##0")₫</span>
                                        }
                                        <span class="product-price-current">@product.Gia.ToString("#,##0")₫</span>
                                    </div>

                                    <!-- Installment button -->
                                    <button type="button" class="btn-installment">
                                        <i class="bi bi-percent"></i> Trả góp 0%
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script src="~/js/pages/home.js"></script>
    <script>
        // Track banner clicks for analytics
        function trackBannerClick(bannerId) {
            fetch(`/api/banneranalytics/track-click/${bannerId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => response.json())
            .then(data => {
                console.log('Banner click tracked:', data);
            })
            .catch(error => {
                console.error('Error tracking banner click:', error);
            });
        }
    </script>
}

@* Cart functionality is now in global wwwroot/js/cart.js *@

@functions {
    // Helper function to get icon for category
    string GetCategoryIcon(int categoryId)
    {
        return categoryId switch
        {
            1 => "bi-laptop",           // Laptop
            2 => "bi-pc-display",       // PC/Desktop
            3 => "bi-keyboard",         // Keyboard/Accessories
            4 => "bi-mouse3",           // Mouse
            5 => "bi-cpu",              // CPU/Components
            6 => "bi-memory",           // RAM/Memory
            7 => "bi-hdd",              // Storage
            8 => "bi-display",          // Monitor
            _ => "bi-box2-heart"        // Default
        };
    }
}
