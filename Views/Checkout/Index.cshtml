@model CheckoutViewModel
@{
    ViewData["Title"] = "Thanh Toán";
}

<link rel="stylesheet" href="~/css/pages/checkout.css" />

<div class="container">
    <div class="checkout-container">
        <!-- Title -->
        <div class="checkout-title">
            <i class="bi bi-credit-card"></i>
            Xác Nhận Thanh Toán
        </div>

        <!-- Error Messages -->
        @if (TempData["Error"] != null)
        {
            <div class="error-message">
                <i class="bi bi-exclamation-circle"></i>
                @TempData["Error"]
            </div>
        }

        <form method="post" novalidate>
            @Html.AntiForgeryToken()
            
            <div class="row">
                <!-- Left: Form -->
                <div class="col-lg-7">
                    <!-- Thông Tin Người Nhận -->
                    <div class="form-section">
                        <h5>
                            <i class="bi bi-person-check"></i>
                            Thông Tin Người Nhận
                        </h5>
                        
                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-person"></i>
                                Họ Tên
                            </label>
                            <input type="text" class="form-control @(ViewData.ModelState["TenNguoiNhan"]?.Errors.Any() == true ? "is-invalid" : "")" 
                                   name="TenNguoiNhan" value="@Model.TenNguoiNhan" placeholder="Nhập họ tên">
                            @if (ViewData.ModelState["TenNguoiNhan"]?.Errors.Any() == true)
                            {
                                <span class="invalid-feedback">@ViewData.ModelState["TenNguoiNhan"].Errors[0].ErrorMessage</span>
                            }
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-envelope"></i>
                                Email
                            </label>
                            <input type="email" class="form-control @(ViewData.ModelState["Email"]?.Errors.Any() == true ? "is-invalid" : "")" 
                                   name="Email" value="@Model.Email" placeholder="Nhập email">
                            @if (ViewData.ModelState["Email"]?.Errors.Any() == true)
                            {
                                <span class="invalid-feedback">@ViewData.ModelState["Email"].Errors[0].ErrorMessage</span>
                            }
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-telephone"></i>
                                Số Điện Thoại
                            </label>
                            <input type="tel" class="form-control @(ViewData.ModelState["SoDienThoai"]?.Errors.Any() == true ? "is-invalid" : "")" 
                                   name="SoDienThoai" value="@Model.SoDienThoai" placeholder="Nhập số điện thoại">
                            @if (ViewData.ModelState["SoDienThoai"]?.Errors.Any() == true)
                            {
                                <span class="invalid-feedback">@ViewData.ModelState["SoDienThoai"].Errors[0].ErrorMessage</span>
                            }
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-geo-alt"></i>
                                Địa Chỉ Giao Hàng
                            </label>
                            <input type="text" class="form-control @(ViewData.ModelState["DiaChiGiaoHang"]?.Errors.Any() == true ? "is-invalid" : "")" 
                                   name="DiaChiGiaoHang" value="@Model.DiaChiGiaoHang" placeholder="Nhập địa chỉ giao hàng">
                            @if (ViewData.ModelState["DiaChiGiaoHang"]?.Errors.Any() == true)
                            {
                                <span class="invalid-feedback">@ViewData.ModelState["DiaChiGiaoHang"].Errors[0].ErrorMessage</span>
                            }
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-chat-left-text"></i>
                                Ghi Chú
                            </label>
                            <textarea class="form-control" name="GhiChu" rows="3" placeholder="Nhập ghi chú (tùy chọn)">@Model.GhiChu</textarea>
                        </div>
                    </div>

                    <!-- Phương Thức Thanh Toán -->
                    <div class="form-section">
                        <h5>
                            <i class="bi bi-wallet2"></i>
                            Phương Thức Thanh Toán
                        </h5>

                        <div class="payment-method active">
                            <input type="radio" id="cod" name="PaymentMethod" value="COD" checked>
                            <label for="cod" style="margin: 0; cursor: pointer; flex: 1;">
                                <i class="bi bi-truck"></i>
                                <strong>Thanh Toán Khi Nhận Hàng (COD)</strong>
                                <br>
                                <small style="color: #666;">Không phí, giao hàng nhanh</small>
                            </label>
                        </div>

                        <div class="payment-method">
                            <input type="radio" id="bank" name="PaymentMethod" value="BANK" disabled>
                            <label for="bank" style="margin: 0; cursor: not-allowed; flex: 1; color: #999;">
                                <i class="bi bi-bank"></i>
                                <strong>Chuyển Khoản Ngân Hàng</strong>
                                <br>
                                <small>(Đang phát triển)</small>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Right: Order Summary -->
                <div class="col-lg-5">
                    <div class="order-summary">
                        <h5>
                            <i class="bi bi-receipt"></i>
                            Tóm Tắt Đơn Hàng
                        </h5>

                        @if (Model.Items != null && Model.Items.Any())
                        {
                            @foreach (var item in Model.Items)
                            {
                                <div class="summary-item">
                                    <div class="summary-item-name">
                                        @item.ProductName
                                    </div>
                                    <div class="summary-item-qty">
                                        ×@item.Quantity
                                    </div>
                                    <div class="summary-item-price">
                                        @((item.Price * item.Quantity).ToString("N0"))₫
                                    </div>
                                </div>
                            }
                        }

                        <div class="summary-divider"></div>

                        <div class="summary-item">
                            <span>Tổng Tiền Hàng:</span>
                            <span style="font-weight: 600; color: var(--hdk-dark);">@Model.TongTien.ToString("N0")₫</span>
                        </div>

                        <div class="summary-item">
                            <span>Phí Vận Chuyển:</span>
                            <span style="font-weight: 600; color: var(--hdk-dark);">@Model.PhiVanChuyen.ToString("N0")₫</span>
                        </div>

                        <div class="summary-total">
                            <span>Tổng Cộng:</span>
                            <span>@((Model.TongTien + Model.PhiVanChuyen).ToString("N0"))₫</span>
                        </div>

                        <button type="submit" class="btn-checkout">
                            <i class="bi bi-check-circle"></i>
                            XÁC NHẬN ĐẶT HÀNG
                        </button>

                        <a href="/Cart" class="btn btn-outline-secondary w-100 mt-2">
                            <i class="bi bi-arrow-left"></i>
                            Quay Lại Giỏ Hàng
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
