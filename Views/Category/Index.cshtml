@model IEnumerable<HDKTech.Models.SanPham>
@{
    ViewData["Title"] = "Danh mục - HDKTech";
    var categoryId = ViewBag.CategoryId as int?;
    var brands = ViewBag.Brands as List<string> ?? new List<string>();
    var cpuLines = ViewBag.CpuLines as List<string> ?? new List<string>();
    var currentSort = ViewBag.CurrentSort as string ?? "featured";
}

<link rel="stylesheet" href="~/css/pages/category.css" />

    <div class="filter-section bg-white p-3 rounded-3 shadow-sm mb-4 border-light">
        <form asp-action="Index" method="get" id="filterForm" class="w-100">
            <input type="hidden" name="id" value="@categoryId" />

            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-muted small"><i class="bi bi-house-fill me-1"></i>Trang chủ</a></li>
                    <li class="breadcrumb-item active small" aria-current="page">@(ViewBag.CategoryName ?? "Danh mục")</li>
                </ol>
            </nav>

            <div class="d-flex flex-wrap gap-2 mb-3">
                <!-- Nút Bộ lọc -->
                <button type="button" class="btn btn-outline-secondary btn-sm px-3 shadow-none fw-bold" data-bs-toggle="collapse" data-bs-target="#advancedFilters">
                    <i class="bi bi-funnel me-1"></i> Bộ lọc nâng cao
                </button>

                <!-- Tình trạng -->
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-check-circle me-1"></i> Tình trạng
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="?id=@categoryId&status=1&sortBy=@currentSort">Còn hàng</a></li>
                        <li><a class="dropdown-item" href="?id=@categoryId&status=0&sortBy=@currentSort">Hết hàng</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="?id=@categoryId&sortBy=@currentSort">Xóa bộ lọc</a></li>
                    </ul>
                </div>

                <!-- Giá -->
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-tag me-1"></i> Giá
                    </button>
                    <ul class="dropdown-menu p-2" style="min-width: 250px;">
                        <li><a class="dropdown-item" href="?id=@categoryId&minPrice=0&maxPrice=5000000&sortBy=@currentSort">Dưới 5 triệu</a></li>
                        <li><a class="dropdown-item" href="?id=@categoryId&minPrice=5000000&maxPrice=10000000&sortBy=@currentSort">5 - 10 triệu</a></li>
                        <li><a class="dropdown-item" href="?id=@categoryId&minPrice=10000000&maxPrice=20000000&sortBy=@currentSort">10 - 20 triệu</a></li>
                        <li><a class="dropdown-item" href="?id=@categoryId&minPrice=20000000&maxPrice=999999999&sortBy=@currentSort">Trên 20 triệu</a></li>
                    </ul>
                </div>

                <!-- Hãng -->
                @if (brands.Any())
                {
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-building me-1"></i> Hãng
                        </button>
                        <ul class="dropdown-menu">
                            @foreach (var brand in brands.Take(10))
                            {
                                <li><a class="dropdown-item" href="?id=@categoryId&brandId=@brand.GetHashCode()&sortBy=@currentSort">@brand</a></li>
                            }
                        </ul>
                    </div>
                }

                <!-- Dòng CPU -->
                @if (cpuLines.Any())
                {
                    <div class="dropdown">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-cpu me-1"></i> Dòng CPU
                        </button>
                        <ul class="dropdown-menu">
                            @foreach (var cpu in cpuLines.Take(8))
                            {
                                <li><a class="dropdown-item" href="?id=@categoryId&cpuLine=@cpu&sortBy=@currentSort">@cpu</a></li>
                            }
                        </ul>
                    </div>
                }

                <!-- Dòng VGA -->
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-gpu me-1"></i> Dòng VGA
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="?id=@categoryId&vgaLine=RTX 4050&sortBy=@currentSort">RTX 4050</a></li>
                        <li><a class="dropdown-item" href="?id=@categoryId&vgaLine=RTX 4060&sortBy=@currentSort">RTX 4060</a></li>
                        <li><a class="dropdown-item" href="?id=@categoryId&vgaLine=RTX 4070&sortBy=@currentSort">RTX 4070</a></li>
                        <li><a class="dropdown-item" href="?id=@categoryId&vgaLine=RTX 4080&sortBy=@currentSort">RTX 4080</a></li>
                    </ul>
                </div>

                <!-- Loại RAM -->
                <div class="dropdown">
                    <button class="btn btn-outline-secondary btn-sm dropdown-toggle px-3" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-memory me-1"></i> Loại RAM
                    </button>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="?id=@categoryId&ramType=DDR4&sortBy=@currentSort">DDR4</a></li>
                        <li><a class="dropdown-item" href="?id=@categoryId&ramType=DDR5&sortBy=@currentSort">DDR5</a></li>
                    </ul>
                </div>
            </div>

            <!-- Sắp xếp -->
            <div class="d-flex justify-content-end border-top pt-3">
                <div class="sort-wrapper border rounded-2 px-3 py-1 bg-light">
                    <span class="small text-muted me-1">
                        <i class="bi bi-sort-down"></i> Xếp theo:
                    </span>
                    <select name="sortBy" class="border-0 bg-transparent fw-bold small sort-select shadow-none" style="cursor:pointer; outline:none;" onchange="document.getElementById('filterForm').submit();">
                        @if (currentSort == "featured")
                        {
                            <option value="featured" selected>Nổi bật</option>
                        }
                        else
                        {
                            <option value="featured">Nổi bật</option>
                        }
                        @if (currentSort == "name_asc")
                        {
                            <option value="name_asc" selected>Tên từ A-Z</option>
                        }
                        else
                        {
                            <option value="name_asc">Tên từ A-Z</option>
                        }
                        @if (currentSort == "name_desc")
                        {
                            <option value="name_desc" selected>Tên từ Z-A</option>
                        }
                        else
                        {
                            <option value="name_desc">Tên từ Z-A</option>
                        }
                        @if (currentSort == "price_asc")
                        {
                            <option value="price_asc" selected>Giá tăng dần</option>
                        }
                        else
                        {
                            <option value="price_asc">Giá tăng dần</option>
                        }
                        @if (currentSort == "price_desc")
                        {
                            <option value="price_desc" selected>Giá giảm dần</option>
                        }
                        else
                        {
                            <option value="price_desc">Giá giảm dần</option>
                        }
                        @if (currentSort == "new")
                        {
                            <option value="new" selected>Mới nhất</option>
                        }
                        else
                        {
                            <option value="new">Mới nhất</option>
                        }
                    </select>
                </div>
            </div>
        </form>
    </div>

    <!-- Danh sách sản phẩm -->
    <div class="products-grid">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="product-card-wrapper">
                    <div class="product-card">
                        <!-- IMAGE SECTION -->
                        <div class="product-image-container">
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@item.MaSanPham" class="product-image-link">
                                @{
                                    var fileName = item.HinhAnhs?.FirstOrDefault(h => h.IsDefault)?.Url
                                                   ?? item.HinhAnhs?.FirstOrDefault()?.Url
                                                   ?? "no-image.png";
                                    var fullPath = "/images/products/" + fileName;
                                }
                                <img src="@fullPath"
                                     alt="@item.TenSanPham"
                                     class="product-image"
                                     onerror="this.onerror=null; this.src='/images/products/no-image.png';">
                            </a>

                            <!-- BADGES -->
                            <span class="product-badge-new">MỚI</span>
                            @if (item.PhanTramGiamGia > 0)
                            {
                                <span class="product-badge-discount">-@item.PhanTramGiamGia%</span>
                            }

                            <!-- ADD TO CART BUTTON -->
                            <button type="button" class="product-add-btn" onclick="addToCartAjax(@item.MaSanPham, '@item.TenSanPham')">
                                <i class="bi bi-cart-plus"></i> Thêm Giỏ
                            </button>
                        </div>

                        <!-- PRODUCT INFO -->
                        <div class="product-info">
                            <h5 class="product-name">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.MaSanPham">
                                    @item.TenSanPham
                                </a>
                            </h5>

                            <!-- Rating -->
                            <div class="product-rating">
                                <div class="rating-stars">
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                    <i class="bi bi-star-fill"></i>
                                </div>
                                <span class="rating-count">Đã bán 234</span>
                            </div>

                            <div class="product-price-group">
                                @if (item.GiaNiemYet.HasValue && item.GiaNiemYet > item.Gia)
                                {
                                    <span class="product-price-old">@item.GiaNiemYet.Value.ToString("#,##0")₫</span>
                                }
                                <span class="product-price-current">@item.Gia.ToString("#,##0")₫</span>
                            </div>

                            <!-- Installment button -->
                            <button type="button" class="btn-installment">
                                <i class="bi bi-percent"></i> Trả góp 0%
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12" style="grid-column: 1 / -1;">
                <div class="alert alert-info text-center py-5">
                    <i class="bi bi-search fs-1 d-block mb-3"></i>
                    <h5>Không tìm thấy sản phẩm</h5>
                    <p class="mb-0">Vui lòng thử bộ lọc khác hoặc <a asp-controller="Home" asp-action="Index" class="fw-bold">quay lại trang chủ</a></p>
                </div>
            </div>
        }
    </div>

                        <!-- ===== PAGINATION ===== -->
                        @if (ViewBag.TotalPages > 1)
                        {
                            <nav aria-label="Page navigation" class="d-flex justify-content-center mt-5 mb-4">
                                <ul class="pagination">
                                    @* Nút Previous *@
                                    <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
                                        <a class="page-link" asp-route-page="@(ViewBag.CurrentPage - 1)" href="#">
                                            <i class="bi bi-chevron-left"></i> Trang Trước
                                        </a>
                                    </li>

                                    @* Các nút số trang *@
                                    @{
                                        int startPage = Math.Max(1, ViewBag.CurrentPage - 2);
                                        int endPage = Math.Min(ViewBag.TotalPages, ViewBag.CurrentPage + 2);

                                        if (startPage > 1)
                                        {
                                            <li class="page-item">
                                                <a class="page-link" asp-route-page="1">1</a>
                                            </li>
                                            if (startPage > 2)
                                            {
                                                <li class="page-item disabled"><span class="page-link">...</span></li>
                                            }
                                        }

                                        for (int i = startPage; i <= endPage; i++)
                                        {
                                            if (i == ViewBag.CurrentPage)
                                            {
                                                <li class="page-item active">
                                                    <span class="page-link">@i</span>
                                                </li>
                                            }
                                            else
                                            {
                                                <li class="page-item">
                                                    <a class="page-link" asp-route-page="@i">@i</a>
                                                </li>
                                            }
                                        }

                                        if (endPage < ViewBag.TotalPages)
                                        {
                                            if (endPage < ViewBag.TotalPages - 1)
                                            {
                                                <li class="page-item disabled"><span class="page-link">...</span></li>
                                            }
                                            <li class="page-item">
                                                <a class="page-link" asp-route-page="@ViewBag.TotalPages">@ViewBag.TotalPages</a>
                                            </li>
                                        }
                                    }

                                    @* Nút Next *@
                                    <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
                                        <a class="page-link" asp-route-page="@(ViewBag.CurrentPage + 1)" href="#">
                                            Trang Sau <i class="bi bi-chevron-right"></i>
                                        </a>
                                    </li>
                                </ul>
                            </nav>

                            @* Info text *@
                            <div class="text-center text-muted small mb-5">
                                <p>Hiển thị <strong>@Model.Count()</strong> sản phẩm / Trang <strong>@ViewBag.CurrentPage</strong> / Tổng <strong>@ViewBag.TotalPages</strong> trang (<strong>@ViewBag.TotalProducts</strong> sản phẩm)</p>
                            </div>
                        }
                    </div>