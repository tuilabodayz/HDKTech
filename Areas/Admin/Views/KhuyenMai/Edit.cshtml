@model KhuyenMai

@{
    ViewData["Title"] = "Chỉnh sửa Khuyến mãi";
}

<div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-on-surface mb-2">Chỉnh sửa Khuyến mãi</h1>
    <p class="text-zinc-500">Cập nhật thông tin chiến dịch khuyến mãi</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Form -->
    <div class="lg:col-span-2">
        <form method="post" class="bg-white rounded-2xl shadow-sm p-8 space-y-6">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="MaKhuyenMai" />

            <!-- Tên chiến dịch -->
            <div>
                <label class="block text-sm font-bold text-on-surface mb-2">
                    Tên chiến dịch <span class="text-red-500">*</span>
                </label>
                <input type="text" asp-for="TenChienDich" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                <span asp-validation-for="TenChienDich" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Mô tả -->
            <div>
                <label class="block text-sm font-bold text-on-surface mb-2">Mô tả</label>
                <textarea asp-for="MoTa" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" rows="3"></textarea>
            </div>

            <!-- Danh mục áp dụng -->
            <div>
                <label class="block text-sm font-bold text-on-surface mb-2">Danh mục áp dụng</label>
                <input type="text" asp-for="DanhMucAp" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
            </div>

            <!-- Ngày -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-bold text-on-surface mb-2">Ngày bắt đầu</label>
                    <input type="datetime-local" asp-for="NgayBatDau" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-on-surface mb-2">Ngày kết thúc</label>
                    <input type="datetime-local" asp-for="NgayKetThuc" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                </div>
            </div>

            <!-- Loại khuyến mãi -->
            <div>
                <label class="block text-sm font-bold text-on-surface mb-2">Loại khuyến mãi</label>
                <select asp-for="LoaiKhuyenMai" id="loaiKhuyenMai" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all">
                    <option value="Percentage">Giảm giá %</option>
                    <option value="FixedAmount">Giảm giá cố định (VNĐ)</option>
                    <option value="FreeShip">Miễn phí vận chuyển</option>
                </select>
            </div>

            <!-- Giá trị -->
            <div id="giaTri-container">
                <label class="block text-sm font-bold text-on-surface mb-2">Giá trị</label>
                <div class="flex gap-2">
                    <input type="number" asp-for="GiaTri" step="0.01" class="flex-1 px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                    <span id="unit" class="px-4 py-2.5 bg-surface-container text-on-surface rounded-lg font-bold">@(Model.LoaiKhuyenMai == "Percentage" ? "%" : Model.LoaiKhuyenMai == "FixedAmount" ? "₫" : "")</span>
                </div>
            </div>

            <!-- Mã khuyến mãi -->
            <div>
                <label class="block text-sm font-bold text-on-surface mb-2">Mã khuyến mãi</label>
                <input type="text" asp-for="MaKhuyenMai_Code" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
            </div>

            <!-- Số lượng -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-bold text-on-surface mb-2">Số lượng tối đa</label>
                    <input type="number" asp-for="SoLuongToiDa" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-on-surface mb-2">Trạng thái</label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" asp-for="IsActive" class="w-4 h-4 rounded border-outline text-primary" />
                        <span class="text-sm font-medium text-on-surface">Kích hoạt</span>
                    </label>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex gap-4 pt-6">
                <button type="submit" class="px-6 py-3 bg-primary text-white rounded-lg font-bold hover:bg-primary-container transition-all">
                    <span class="material-symbols-outlined inline mr-2">save</span>Cập nhật
                </button>
                <a href="@Url.Action("Index")" class="px-6 py-3 border border-outline text-on-surface rounded-lg font-bold hover:bg-surface-container transition-all">
                    Hủy
                </a>
            </div>
        </form>
    </div>

    <!-- Info -->
    <div>
        <div class="bg-white rounded-2xl shadow-sm p-6 sticky top-24 space-y-4">
            <div>
                <span class="text-xs font-bold text-zinc-600 uppercase">Trạng thái hiện tại</span>
                <p class="text-lg font-bold text-on-surface">@Model.TrangThai</p>
            </div>

            <div class="border-t border-surface-container pt-4">
                <span class="text-xs font-bold text-zinc-600 uppercase">Số lần sử dụng</span>
                <p class="text-lg font-bold text-on-surface">@Model.SoLuongSuDung @(Model.SoLuongToiDa.HasValue ? $"/ {Model.SoLuongToiDa}" : "")</p>
            </div>

            <div class="border-t border-surface-container pt-4">
                <span class="text-xs font-bold text-zinc-600 uppercase">Ngày tạo</span>
                <p class="text-sm text-on-surface">@Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</p>
            </div>

            @if (Model.NgayCapNhat.HasValue)
            {
                <div class="border-t border-surface-container pt-4">
                    <span class="text-xs font-bold text-zinc-600 uppercase">Cập nhật lần cuối</span>
                    <p class="text-sm text-on-surface">@Model.NgayCapNhat.Value.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            }
        </div>
    </div>
</div>

<script>
    const loaiSelect = document.getElementById('loaiKhuyenMai');
    const unitSpan = document.getElementById('unit');

    loaiSelect.addEventListener('change', function() {
        if (this.value === 'Percentage') {
            unitSpan.textContent = '%';
        } else if (this.value === 'FixedAmount') {
            unitSpan.textContent = '₫';
        } else {
            unitSpan.textContent = '';
        }
    });
</script>
