@model KhuyenMai

@{
    ViewData["Title"] = "Tạo Khuyến mãi Mới";
}

<div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-on-surface mb-2">Tạo Khuyến mãi Mới</h1>
    <p class="text-zinc-500">Thêm một chiến dịch khuyến mãi mới</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Form -->
    <div class="lg:col-span-2">
        <form method="post" class="bg-white rounded-2xl shadow-sm p-8 space-y-6">
            @Html.AntiForgeryToken()

            <!-- Tên chiến dịch -->
            <div>
                <label class="block text-sm font-bold text-on-surface mb-2">
                    Tên chiến dịch <span class="text-red-500">*</span>
                </label>
                <input type="text" asp-for="TenChienDich" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="VD: Back to School 2024" />
                <span asp-validation-for="TenChienDich" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Mô tả -->
            <div>
                <label class="block text-sm font-bold text-on-surface mb-2">Mô tả</label>
                <textarea asp-for="MoTa" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" rows="3" placeholder="Mô tả về chiến dịch..."></textarea>
            </div>

            <!-- Danh mục áp dụng -->
            <div>
                <label class="block text-sm font-bold text-on-surface mb-2">Danh mục áp dụng</label>
                <input type="text" asp-for="DanhMucAp" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="VD: Laptop & Accessories" />
            </div>

            <!-- Ngày bắt đầu -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-bold text-on-surface mb-2">
                        Ngày bắt đầu <span class="text-red-500">*</span>
                    </label>
                    <input type="datetime-local" asp-for="NgayBatDau" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                    <span asp-validation-for="NgayBatDau" class="text-xs text-red-500 mt-1 block"></span>
                </div>
                <div>
                    <label class="block text-sm font-bold text-on-surface mb-2">
                        Ngày kết thúc <span class="text-red-500">*</span>
                    </label>
                    <input type="datetime-local" asp-for="NgayKetThuc" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" />
                    <span asp-validation-for="NgayKetThuc" class="text-xs text-red-500 mt-1 block"></span>
                </div>
            </div>

            <!-- Loại khuyến mãi -->
            <div>
                <label class="block text-sm font-bold text-on-surface mb-2">
                    Loại khuyến mãi <span class="text-red-500">*</span>
                </label>
                <select asp-for="LoaiKhuyenMai" id="loaiKhuyenMai" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all">
                    <option value="">-- Chọn loại --</option>
                    <option value="Percentage">Giảm giá %</option>
                    <option value="FixedAmount">Giảm giá cố định (VNĐ)</option>
                    <option value="FreeShip">Miễn phí vận chuyển</option>
                </select>
                <span asp-validation-for="LoaiKhuyenMai" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Giá trị khuyến mãi -->
            <div id="giaTri-container">
                <label class="block text-sm font-bold text-on-surface mb-2">
                    Giá trị <span class="text-red-500">*</span>
                </label>
                <div class="flex gap-2">
                    <input type="number" asp-for="GiaTri" step="0.01" class="flex-1 px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="0" />
                    <span id="unit" class="px-4 py-2.5 bg-surface-container text-on-surface rounded-lg font-bold">%</span>
                </div>
                <span asp-validation-for="GiaTri" class="text-xs text-red-500 mt-1 block"></span>
            </div>

            <!-- Mã khuyến mãi -->
            <div>
                <label class="block text-sm font-bold text-on-surface mb-2">Mã khuyến mãi</label>
                <input type="text" asp-for="MaKhuyenMai_Code" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="VD: BACK2024" />
                <p class="text-xs text-zinc-500 mt-1">Để trống nếu không sử dụng mã</p>
            </div>

            <!-- Số lượng tối đa -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-bold text-on-surface mb-2">Số lượng tối đa</label>
                    <input type="number" asp-for="SoLuongToiDa" class="w-full px-4 py-2.5 border border-outline rounded-lg focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all" placeholder="Không giới hạn nếu để trống" />
                </div>
                <div>
                    <label class="block text-sm font-bold text-on-surface mb-2">Trạng thái</label>
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" asp-for="IsActive" class="w-4 h-4 rounded border-outline text-primary" checked />
                        <span class="text-sm font-medium text-on-surface">Kích hoạt</span>
                    </label>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex gap-4 pt-6">
                <button type="submit" class="px-6 py-3 bg-primary text-white rounded-lg font-bold hover:bg-primary-container transition-all">
                    <span class="material-symbols-outlined inline mr-2">save</span>Tạo chiến dịch
                </button>
                <a href="@Url.Action("Index")" class="px-6 py-3 border border-outline text-on-surface rounded-lg font-bold hover:bg-surface-container transition-all">
                    Hủy
                </a>
            </div>
        </form>
    </div>

    <!-- Preview -->
    <div>
        <div class="bg-white rounded-2xl shadow-sm p-6 sticky top-24">
            <h3 class="text-lg font-bold text-on-surface mb-4">Xem trước</h3>

            <div class="space-y-4">
                <div>
                    <span class="font-medium text-zinc-600 text-sm">Tên chiến dịch</span>
                    <p id="previewName" class="text-on-surface font-bold">-</p>
                </div>

                <div class="border-t border-surface-container pt-4">
                    <span class="font-medium text-zinc-600 text-sm">Khuyến mãi</span>
                    <p id="previewPromo" class="text-lg font-black text-primary">-</p>
                </div>

                <div class="border-t border-surface-container pt-4">
                    <span class="font-medium text-zinc-600 text-sm">Thời gian</span>
                    <p id="previewTime" class="text-sm text-on-surface">-</p>
                </div>

                <div class="border-t border-surface-container pt-4">
                    <span class="font-medium text-zinc-600 text-sm">Trạng thái</span>
                    <p id="previewStatus" class="text-sm font-bold text-amber-600">Sắp diễn ra</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const loaiSelect = document.getElementById('loaiKhuyenMai');
    const unitSpan = document.getElementById('unit');
    const previewName = document.getElementById('previewName');
    const previewPromo = document.getElementById('previewPromo');
    const previewTime = document.getElementById('previewTime');

    loaiSelect.addEventListener('change', function() {
        if (this.value === 'Percentage') {
            unitSpan.textContent = '%';
        } else if (this.value === 'FixedAmount') {
            unitSpan.textContent = '₫';
        } else {
            unitSpan.textContent = '';
        }
    });

    document.getElementById('TenChienDich').addEventListener('input', (e) => {
        previewName.textContent = e.target.value || '-';
    });

    document.getElementById('GiaTri').addEventListener('input', updatePreview);
    document.getElementById('loaiKhuyenMai').addEventListener('change', updatePreview);

    function updatePreview() {
        const giaTri = document.getElementById('GiaTri').value;
        const loai = loaiSelect.value;
        
        let text = '-';
        if (giaTri && loai) {
            if (loai === 'Percentage') text = `Giảm ${giaTri}%`;
            else if (loai === 'FixedAmount') text = `Giảm ${parseInt(giaTri).toLocaleString('vi-VN')}₫`;
            else text = `Miễn phí vận chuyển`;
        }
        previewPromo.textContent = text;
    }
</script>
