@model HDKTech.Models.HangSX

@{
    ViewData["Title"] = "Chỉnh sửa Thương Hiệu";
}

<div class="p-8">
    <!-- Header -->
    <div class="mb-10">
        <div class="flex items-center gap-3 mb-2">
            <a href="@Url.Action("Index", "Brand", new { area = "Admin" })" class="text-primary hover:underline text-sm font-medium flex items-center gap-1">
                <span class="material-symbols-outlined">chevron_left</span>
                Quay lại
            </a>
        </div>
        <h1 class="text-3xl font-extrabold text-on-surface tracking-tight">Chỉnh sửa Thương Hiệu</h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Form -->
        <div class="lg:col-span-2">
            <form asp-action="Edit" asp-controller="Brand" asp-area="Admin" method="post" class="space-y-6">
                <input type="hidden" asp-for="MaHangSX" />

                <!-- Tên Thương Hiệu -->
                <div class="bg-surface-container-lowest p-6 rounded-lg shadow-sm">
                    <label asp-for="TenHangSX" class="block text-sm font-bold text-on-surface mb-2">Tên Thương Hiệu <span class="text-error">*</span></label>
                    <input type="text" asp-for="TenHangSX" placeholder="Nhập tên thương hiệu" class="w-full px-4 py-2.5 border border-surface-container-high rounded-lg focus:ring-2 focus:ring-primary/40 outline-none" />
                    <span asp-validation-for="TenHangSX" class="text-xs text-error mt-1 block"></span>
                </div>

                <!-- Mô Tả -->
                <div class="bg-surface-container-lowest p-6 rounded-lg shadow-sm">
                    <label asp-for="MoTa" class="block text-sm font-bold text-on-surface mb-2">Mô Tả</label>
                    <textarea asp-for="MoTa" placeholder="Nhập mô tả thương hiệu" rows="5" class="w-full px-4 py-2.5 border border-surface-container-high rounded-lg focus:ring-2 focus:ring-primary/40 outline-none resize-none"></textarea>
                    <span asp-validation-for="MoTa" class="text-xs text-error mt-1 block"></span>
                </div>

                <!-- Buttons -->
                <div class="flex gap-3">
                    <button type="submit" class="px-6 py-2.5 bg-primary hover:brightness-110 text-white rounded-lg font-bold text-sm transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined">check</span>
                        Cập nhật
                    </button>
                    <a href="@Url.Action("Index", "Brand", new { area = "Admin" })" class="px-6 py-2.5 bg-surface-container-high hover:bg-surface-container text-on-surface rounded-lg font-bold text-sm transition-colors flex items-center gap-2">
                        <span class="material-symbols-outlined">close</span>
                        Hủy
                    </a>
                </div>
            </form>
        </div>

        <!-- Info Panel -->
        <div class="space-y-6">
            <div class="bg-surface-container-lowest p-6 rounded-lg shadow-sm">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined">info</span>
                    Thông tin
                </h2>
                <div class="space-y-3 text-sm text-zinc-600">
                    <div>
                        <p class="font-bold text-on-surface mb-1">Mã Thương Hiệu</p>
                        <p class="text-primary">#@Model?.MaHangSX</p>
                    </div>
                    <div>
                        <p class="font-bold text-on-surface mb-1">Ngôn ngữ</p>
                        <p>Tiếng Việt</p>
                    </div>
                    <div>
                        <p class="font-bold text-on-surface mb-1">Trạng thái</p>
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-tertiary-fixed/30 text-on-tertiary">Hoạt động</span>
                    </div>
                </div>
            </div>

            <div class="bg-primary/10 p-6 rounded-lg border-l-4 border-primary">
                <p class="text-sm text-on-surface">
                    <span class="font-bold">💡 Tip:</span> Bạn có thể cập nhật bất kỳ thông tin nào về thương hiệu từ đây
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
