@model IEnumerable<HDKTech.Models.DanhMuc>

<div class="list-group list-group-flush sidebar-mega-menu">
    @* BƯỚC 1: LỌC CÁC DANH MỤC CHA (TẦNG 1) *@
    @foreach (var parent in Model.Where(m => m.MaDanhMucCha == null))
    {
        <div class="menu-item-container">
            @* CLICK VÀO ĐÂY: Dẫn đến trang lọc theo Danh mục Cha *@
            <a asp-area="" asp-controller="Category" asp-action="Index" asp-route-id="@parent.MaDanhMuc"
                   class="list-group-item list-group-item-action border-0 py-3 d-flex justify-content-between align-items-center">
                <span><i class="bi bi-cpu me-2"></i> @parent.TenDanhMuc</span>
                <i class="bi bi-chevron-right small"></i>
            </a>

            @* DI CHUỘT VÀO: Hiện bảng Mega Menu *@
            <div class="mega-menu-panel shadow-lg">
                <div class="row g-4">
                    @* BƯỚC 2: LỌC CÁC NHÓM CON (TẦNG 2 - Tiêu đề đỏ) *@
                    @foreach (var group in Model.Where(m => m.MaDanhMucCha == parent.MaDanhMuc))
                    {
                        <div class="col-md-4">
                            <h6 class="text-danger fw-bold mb-3 text-uppercase">@group.TenDanhMuc</h6>
                            
                            <ul class="list-unstyled">
                                @* BƯỚC 3: LỌC CHI TIẾT (TẦNG 3 - Link nhỏ) *@
                                @foreach (var child in Model.Where(m => m.MaDanhMucCha == group.MaDanhMuc))
                                {
                                    <li class="mb-2">
                                        <a asp-area="" asp-controller="Category" asp-action="Index" asp-route-id="@child.MaDanhMuc"
                                               class="text-decoration-none text-dark small-link">
                                            @child.TenDanhMuc
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>