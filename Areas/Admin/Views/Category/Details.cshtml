@{
    ViewData["Title"] = "Chi tiết Danh Mục";
    var category = (HDKTech.Models.DanhMuc)ViewBag.Category;
}

<div class="p-8">
    <!-- Header -->
    <div class="mb-8 flex items-center justify-between">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <a href="@Url.Action("Index", "Category", new { area = "Admin" })" class="text-primary hover:underline text-sm font-medium flex items-center gap-1">
                    <span class="material-symbols-outlined">chevron_left</span>
                    Quay lại
                </a>
            </div>
            <h1 class="text-3xl font-extrabold text-on-surface tracking-tight">Danh Mục: <span class="text-primary">@category.TenDanhMuc</span></h1>
        </div>
        <a href="@Url.Action("Edit", "Category", new { area = "Admin", id = category.MaDanhMuc })" class="px-4 py-2.5 bg-primary hover:brightness-110 text-white rounded-lg font-bold text-sm flex items-center gap-2 transition-colors">
            <span class="material-symbols-outlined text-lg">edit</span>
            Chỉnh sửa
        </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Category Info -->
            <div class="bg-surface-container-lowest p-6 rounded-lg shadow-sm border-l-4 border-primary">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined">info</span>
                    Thông tin danh mục
                </h2>
                <div class="space-y-4">
                    <div>
                        <p class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-1">Mã Danh Mục</p>
                        <p class="text-sm font-bold text-on-surface">#@category.MaDanhMuc</p>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-1">Tên Danh Mục</p>
                        <p class="text-sm font-bold text-on-surface">@category.TenDanhMuc</p>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-1">Mô Tả</p>
                        <p class="text-sm text-on-surface">@(category.MoTaDanhMuc ?? "Chưa có mô tả")</p>
                    </div>
                    @if (!string.IsNullOrEmpty(category.BannerImageUrl))
                    {
                        <div>
                            <p class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-2">Banner</p>
                            <img src="@category.BannerImageUrl" alt="@category.TenDanhMuc" class="w-full h-40 object-cover rounded-lg" />
                        </div>
                    }
                </div>
            </div>

            <!-- Subcategories -->
            @if (category.DanhMucCon != null && category.DanhMucCon.Count > 0)
            {
                <div class="bg-surface-container-lowest rounded-lg shadow-sm overflow-hidden">
                    <div class="p-6 border-b border-surface-container">
                        <h2 class="text-lg font-bold flex items-center gap-2">
                            <span class="material-symbols-outlined">folder_open</span>
                            Danh mục con (@category.DanhMucCon.Count)
                        </h2>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 p-6">
                        @foreach (var subcategory in category.DanhMucCon)
                        {
                            <div class="p-4 border border-surface-container rounded-lg hover:bg-surface-container-low transition-colors">
                                <div class="flex items-start justify-between mb-2">
                                    <h3 class="font-bold text-on-surface">@subcategory.TenDanhMuc</h3>
                                    <span class="inline-flex items-center px-2 py-1 rounded text-xs font-bold bg-tertiary-fixed/30 text-on-tertiary">
                                        @(subcategory.SanPhams?.Count ?? 0)
                                    </span>
                                </div>
                                <p class="text-xs text-zinc-500 mb-3">@(subcategory.MoTaDanhMuc ?? "Không có mô tả")</p>
                                <a href="@Url.Action("Details", "Category", new { area = "Admin", id = subcategory.MaDanhMuc })" class="text-xs text-primary hover:underline font-medium">
                                    Xem chi tiết →
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Products -->
            @if (category.SanPhams != null && category.SanPhams.Count > 0)
            {
                <div class="bg-surface-container-lowest rounded-lg shadow-sm overflow-hidden">
                    <div class="p-6 border-b border-surface-container">
                        <h2 class="text-lg font-bold flex items-center gap-2">
                            <span class="material-symbols-outlined">shopping_bag</span>
                            Sản phẩm (@category.SanPhams.Count)
                        </h2>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider border-b border-surface-container bg-surface-container-low">
                                    <th class="px-6 py-4">Tên Sản Phẩm</th>
                                    <th class="px-6 py-4">Giá</th>
                                    <th class="px-6 py-4 text-center">Kho</th>
                                    <th class="px-6 py-4 text-center">Hành Động</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-surface-container">
                                @foreach (var product in category.SanPhams.Take(10))
                                {
                                    <tr class="hover:bg-surface-container-low transition-colors">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-3">
                                                @if (product.HinhAnhs?.FirstOrDefault() != null)
                                                {
                                                    <img src="@product.HinhAnhs.FirstOrDefault().Url" alt="@product.TenSanPham" class="w-10 h-10 rounded object-cover" />
                                                }
                                                else
                                                {
                                                    <div class="w-10 h-10 rounded bg-surface-container flex items-center justify-center">
                                                        <span class="material-symbols-outlined text-zinc-400">image</span>
                                                    </div>
                                                }
                                                <p class="text-sm font-semibold text-on-surface">@product.TenSanPham</p>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-sm font-bold text-primary">@product.Gia.ToString("C0")</td>
                                        <td class="px-6 py-4 text-center">
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold @(product.KhoHangs?.Sum(k => k.SoLuong) > 0 ? "bg-tertiary-fixed/30 text-on-tertiary" : "bg-error-container/30 text-on-error-container")">
                                                @(product.KhoHangs?.Sum(k => k.SoLuong) ?? 0)
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-center">
                                            <a href="@Url.Action("Details", "Product", new { area = "Admin", id = product.MaSanPham })" class="text-primary hover:underline text-xs font-medium">
                                                Xem →
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (category.SanPhams.Count > 10)
                    {
                        <div class="px-6 py-4 border-t border-surface-container text-center bg-surface-container-low">
                            <p class="text-xs text-zinc-500">Hiển thị 10 trong @category.SanPhams.Count sản phẩm</p>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
            <!-- Stats -->
            <div class="bg-surface-container-lowest p-6 rounded-lg shadow-sm">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined">analytics</span>
                    Thống kê
                </h2>
                <div class="space-y-4">
                    <div>
                        <p class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-2">Sản phẩm</p>
                        <p class="text-2xl font-bold text-on-surface">@(category.SanPhams?.Count ?? 0)</p>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-2">Danh mục con</p>
                        <p class="text-2xl font-bold text-on-surface">@(category.DanhMucCon?.Count ?? 0)</p>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-zinc-500 uppercase tracking-wide mb-2">Danh mục cha</p>
                        <p class="text-sm text-on-surface">
                            @if (category.DanhMucCha != null)
                            {
                                <a href="@Url.Action("Details", "Category", new { area = "Admin", id = category.DanhMucCha.MaDanhMuc })" class="text-primary hover:underline">
                                    @category.DanhMucCha.TenDanhMuc
                                </a>
                            }
                            else
                            {
                                <span class="text-zinc-500">-</span>
                            }
                        </p>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="bg-surface-container-lowest p-6 rounded-lg shadow-sm">
                <h2 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined">build</span>
                    Hành động
                </h2>
                <div class="space-y-2">
                    <a href="@Url.Action("Edit", "Category", new { area = "Admin", id = category.MaDanhMuc })" class="w-full px-4 py-2.5 bg-primary hover:brightness-110 text-white rounded-lg font-bold text-sm transition-colors flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">edit</span>
                        Chỉnh sửa
                    </a>
                    <button type="button" id="deleteBtn" class="w-full px-4 py-2.5 bg-error hover:brightness-110 text-white rounded-lg font-bold text-sm transition-colors flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined">delete</span>
                        Xóa danh mục
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('deleteBtn').addEventListener('click', function() {
            if (confirm('Bạn có chắc muốn xóa danh mục này? Danh mục phải không có sản phẩm hoặc danh mục con.')) {
                fetch('@Url.Action("Delete", "Category", new { area = "Admin" })', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ categoryId: @category.MaDanhMuc })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert(data.message);
                        window.location.href = '@Url.Action("Index", "Category", new { area = "Admin" })';
                    } else {
                        alert(data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Đã xảy ra lỗi');
                });
            }
        });
    </script>
}
