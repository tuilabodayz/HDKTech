@model List<BannerAnalytics>
@{
    ViewData["Title"] = "Banner Analytics - Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3">📊 Banner Analytics Dashboard</h1>
            <p class="text-muted">Theo dõi hiệu suất các banner marketing của bạn</p>
        </div>
        <div>
            <form method="post" action="/Admin/BannerAnalytics/Cleanup" class="d-inline">
                <button type="submit" class="btn btn-warning btn-sm" onclick="return confirm('Xóa dữ liệu cũ hơn 90 ngày?')">
                    <i class="bi bi-trash"></i> Dọn dẹp dữ liệu
                </button>
            </form>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        @if (Model.Any())
        {
            var totalClicks = Model.Sum(a => a.TotalClicks);
            var totalUniqueIps = Model.Sum(a => a.UniqueIpAddresses);
            var topBanner = Model.OrderByDescending(a => a.TotalClicks).FirstOrDefault();

            <div class="col-md-3 mb-3">
                <div class="card border-left-danger shadow h-100">
                    <div class="card-body">
                        <div class="text-danger small font-weight-bold text-uppercase mb-1">
                            Tổng Clicks
                        </div>
                        <div class="h3 mb-0 text-dark">
                            @totalClicks.ToString("N0")
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card border-left-info shadow h-100">
                    <div class="card-body">
                        <div class="text-info small font-weight-bold text-uppercase mb-1">
                            Unique IPs
                        </div>
                        <div class="h3 mb-0 text-dark">
                            @totalUniqueIps.ToString("N0")
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card border-left-success shadow h-100">
                    <div class="card-body">
                        <div class="text-success small font-weight-bold text-uppercase mb-1">
                            Total Banners
                        </div>
                        <div class="h3 mb-0 text-dark">
                            @Model.Count
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card border-left-warning shadow h-100">
                    <div class="card-body">
                        <div class="text-warning small font-weight-bold text-uppercase mb-1">
                            Top Banner
                        </div>
                        <div class="h6 mb-0 text-dark">
                            @topBanner?.BannerName (@topBanner?.TotalClicks clicks)
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Chưa có dữ liệu click nào
                </div>
            </div>
        }
    </div>

    <!-- Banners Table -->
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h5 class="m-0 font-weight-bold text-primary">
                <i class="bi bi-image"></i> Chi tiết các Banner
            </h5>
        </div>
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-start">Banner</th>
                                <th class="text-center">Loại</th>
                                <th class="text-center">Total Clicks</th>
                                <th class="text-center">Hôm Nay</th>
                                <th class="text-center">30 Ngày</th>
                                <th class="text-center">Unique IPs</th>
                                <th class="text-center">Last Click</th>
                                <th class="text-center">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var analytics in Model.OrderByDescending(a => a.TotalClicks))
                            {
                                <tr>
                                    <td class="text-start">
                                        <strong>@analytics.BannerName</strong>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-info">@analytics.BannerType</span>
                                    </td>
                                    <td class="text-center">
                                        <strong class="text-danger">@analytics.TotalClicks.ToString("N0")</strong>
                                    </td>
                                    <td class="text-center">
                                        @analytics.ClicksToday
                                    </td>
                                    <td class="text-center">
                                        @analytics.ClicksLast30Days
                                    </td>
                                    <td class="text-center">
                                        @analytics.UniqueIpAddresses
                                    </td>
                                    <td class="text-center">
                                        @if (analytics.LastClickDate.HasValue)
                                        {
                                            <small>@analytics.LastClickDate?.ToString("dd/MM/yyyy HH:mm")</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">-</small>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a href="/Admin/BannerAnalytics/Details/@analytics.BannerId" class="btn btn-sm btn-info" title="Chi tiết">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="/Admin/BannerAnalytics/Clicks/@analytics.BannerId" class="btn btn-sm btn-warning" title="Click Events">
                                            <i class="bi bi-list"></i>
                                        </a>
                                        <a href="/Admin/BannerAnalytics/Export/@analytics.BannerId" class="btn btn-sm btn-success" title="Export CSV">
                                            <i class="bi bi-download"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    <i class="bi bi-exclamation-triangle"></i> Không có banner nào để hiển thị
                </div>
            }
        </div>
    </div>
</div>

<style>
    .border-left-danger {
        border-left: 0.25rem solid #ef4444 !important;
    }

    .border-left-info {
        border-left: 0.25rem solid #3b82f6 !important;
    }

    .border-left-success {
        border-left: 0.25rem solid #10b981 !important;
    }

    .border-left-warning {
        border-left: 0.25rem solid #f59e0b !important;
    }

    .card {
        border-radius: 0.5rem;
        border: 1px solid #e5e7eb;
    }

    .table-hover tbody tr:hover {
        background-color: #f9fafb;
    }

    .btn-sm {
        padding: 0.25rem 0.5rem;
        font-size: 0.8rem;
    }
</style>
